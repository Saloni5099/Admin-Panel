# Required: MongoDB connection string
MONGODB_URI=mongodb://127.0.0.1:27017/mern_admin

# Required: Secret for JWT signing (min 16 characters). Use a long random string in production.
JWT_SECRET_KEY=your_secret_key_at_least_16_characters

# Optional: Allowed CORS origin (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# Optional: Email of user to promote to admin (for: npm run set-admin)
ADMIN_EMAIL=admin@example.com
